generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("ADMIN") // ADMIN, WAITER, CASHIER, KITCHEN, BARISTA
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Meal {
  id              String          @id @default(cuid())
  title           String
  titleAr         String          @default("")
  description     String          @default("")
  descriptionAr   String          @default("")
  price           Float
  prepTime        String          @default("15 دقيقة")
  category        String          @default("مشويات")
  categoryAr      String          @default("")
  preparationArea String          @default("KITCHEN") // KITCHEN, BARISTA, HALL
  imageUrl        String          @default("")
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  addons          AddOn[]
  promotionMeals  PromotionMeal[]

}

model AddOn {
  id            String   @id @default(cuid())
  mealId        String
  title         String
  titleAr       String   @default("")
  price         Float    @default(0)
  imageUrl      String   @default("")
  isRecommended Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  meal          Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([mealId])
}

model Promotion {
  id             String        @id @default(cuid())
  bannerImageUrl String
  title          String        @default("")
  titleAr        String        @default("")
  description    String        @default("")
  descriptionAr  String        @default("")
  price          Float         @default(0)
  oldPrice       Float         @default(0)
  discount       Int           @default(0)
  buttonText     String        @default("")
  buttonTextAr   String        @default("")
  buttonLink     String        @default("")
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  mealItems      PromotionMeal[]

}

model PromotionMeal {
  id          String    @id @default(cuid())
  promotionId String
  mealId      String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  meal        Meal      @relation(fields: [mealId], references: [id])

  @@unique([promotionId, mealId])
  @@index([promotionId])
  @@index([mealId])
}

model Shift {
  id            String    @id @default(cuid())
  status        String    @default("OPEN")
  startedBy     String?
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  endedBy       String?
  notes         String?
  totalRevenue  Float     @default(0)
  totalExpenses Float     @default(0)
  netRevenue    Float     @default(0)
  totalDiscounts Float    @default(0)
  totalLoyaltyDiscounts Float @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders   Order[]
  expenses Expense[]
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     Int
  type            String      @default("DINE_IN") // DINE_IN, TAKEAWAY, DELIVERY
  status          String      @default("PENDING") // PENDING, CONFIRMED, PREPARING, READY, READY_TO_PAY, DELIVERED, CANCELLED
  customerName    String      @default("")
  customerPhone   String      @default("")
  customerEmail   String      @default("")
  deliveryAddress String      @default("")
  tableNumber     String      @default("")
  pickupTime      String      @default("")
  subtotal        Float       @default(0)
  serviceCharge   Float       @default(0)
  deliveryFee     Float       @default(0)
  total           Float       @default(0)
  discountType    String      @default("")
  discountValue   Float       @default(0)
  discountAmount  Float       @default(0)
  discountReason  String      @default("")
  discountAppliedBy String    @default("")
  kitchenAccess   Boolean     @default(false)
  baristaAccess   Boolean     @default(false)
  kitchenStatus   String      @default("PENDING")
  baristaStatus   String      @default("PENDING")
  kitchenReceivedAt DateTime?
  baristaReceivedAt DateTime?
  notes           String      @default("")
  cancelledBy     String?
  shiftId         String?
  webUserId       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  shift           Shift?      @relation(fields: [shiftId], references: [id])
  items           OrderItem[]
  webUser         WebUser?    @relation(fields: [webUserId], references: [id])

  @@unique([shiftId, orderNumber])
  @@index([status])
  @@index([shiftId])
  @@index([createdAt])
}

model OrderItem {
  id                String   @id @default(cuid())
  orderId           String
  mealId            String
  mealTitle         String
  mealTitleAr       String   @default("")
  quantity          Int      @default(1)
  price             Float
  preparationArea   String   @default("KITCHEN")
  imageUrl          String   @default("")
  addOns            String   @default("[]")
  category          String   @default("")
  isPromotion       Boolean  @default(false)
  notes             String   @default("")
  lastAddedQuantity Int      @default(0)
  addedQuantity     Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([mealId])
}

model Expense {
  id          String   @id @default(cuid())
  category    String
  description String
  amount      Float
  shiftId     String?
  createdBy   String   @default("")
  employeeId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shift       Shift?   @relation(fields: [shiftId], references: [id])
  employee    Employee? @relation(fields: [employeeId], references: [id])

  @@index([shiftId])
  @@index([employeeId])
}

model Employee {
  id             String   @id @default(cuid())
  name           String
  jobTitle       String
  specialization String   @default("")
  salary         Float    @default(0)
  dailyHours     Float    @default(8)  // agreed working hours per day
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  expenses    Expense[]
  attendances Attendance[]
  dailyLogs   DailyLog[]

  @@index([name])
  @@index([jobTitle])
}

model Attendance {
  id         String   @id @default(cuid())
  employeeId String
  date       DateTime?
  type       String   // VACATION, ABSENCE
  quantity   Float    @default(1)
  notes      String   @default("")
  createdBy  String   @default("")
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model DailyLog {
  id              String   @id @default(cuid())
  employeeId      String
  date            DateTime @default(now())
  clockIn         DateTime?
  clockOut        DateTime?
  status          String   @default("PRESENT") // PRESENT, LATE, ABSENT
  overtimeMinutes Int      @default(0)
  notes           String   @default("")
  recordedBy      String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([date])
}

model RestaurantTable {
  id         String   @id @default(cuid())
  number     Int
  name       String   @default("")
  secretCode String   @unique
  seats      Int      @default(4)
  area       String   @default("صالة رئيسية")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([number, area])
}

model StoreSettings {
  id          String   @id @default("default")
  takingOrders Boolean @default(true)
  message     String   @default("المطعم مغلق حالياً، لا يمكن استقبال الطلبات")
  openTime    String   @default("09:00")
  closeTime   String   @default("23:00")
  closeWarningMinutes Int  @default(10)
  autoCloseMinutes     Int  @default(10)
  loyaltyEnabled  Boolean @default(false)
  loyaltyThreshold Float   @default(1000)
  loyaltyCashback  Float   @default(50)
  areas       String[] @default([])
  updatedAt   DateTime @updatedAt
}

model WebUser {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String    @default("")
  phone     String    @default("")
  picture   String    @default("")
  isBlocked Boolean   @default(false)
  totalSpent Float    @default(0)
  pointsBalance Int   @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  orders    Order[]
  addresses Address[]
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String   @default("المنزل")
  address   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      WebUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String   @default("")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonthlyHandover {
  id          String   @id @default(cuid())
  month       Int      // 1-12
  year        Int
  totalRevenue Float   @default(0)
  totalExpenses Float  @default(0)
  totalDiscounts Float @default(0)
  netRevenue   Float   @default(0)
  handedOverBy String
  notes       String   @default("")
  createdAt   DateTime @default(now())

  @@unique([month, year])
  @@index([year, month])
}
